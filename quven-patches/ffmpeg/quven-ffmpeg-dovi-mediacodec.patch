+static void mediacodec_dovi_reset(MediaCodecH264DecContext *s)
+{
+    for (int i = 0; i < FF_ARRAY_ELEMS(s->dovi_stash); i++) {
+        av_freep(&s->dovi_stash[i].rpu);
+        s->dovi_stash[i].pts = AV_NOPTS_VALUE;
+        s->dovi_stash[i].size = 0;
+    }
+    ff_dovi_ctx_flush(&s->dovi_ctx);
+}
+
+/* MediaCodec consumes the bitstream opaquely, so the Dolby Vision RPU NALs
+ * (HEVC UNSPEC62) never surface as frame side data the way hevcdec attaches
+ * them. Scan each input packet for RPUs, stash them by pts, and re-attach on
+ * the matching output frame. */
+static void mediacodec_dovi_scan(AVCodecContext *avctx,
+                                 MediaCodecH264DecContext *s,
+                                 const AVPacket *pkt)
+{
+    if (avctx->codec_id != AV_CODEC_ID_HEVC || !pkt->size)
+        return;
+
+    size_t sd_size;
+    uint8_t *sd = av_packet_get_side_data(pkt, AV_PKT_DATA_DOVI_CONF, &sd_size);
+    if (sd && sd_size >= sizeof(s->dovi_ctx.cfg))
+        s->dovi_ctx.cfg = *(AVDOVIDecoderConfigurationRecord *) sd;
+    if (!s->dovi_ctx.cfg.dv_profile)
+        return;
+
+    if (ff_h2645_packet_split(&s->dovi_pkt, pkt->data, pkt->size, avctx, 0,
+                              AV_CODEC_ID_HEVC, H2645_FLAG_SMALL_PADDING) < 0)
+        return;
+
+    for (int i = 0; i < s->dovi_pkt.nb_nals; i++) {
+        H2645NAL *nal = &s->dovi_pkt.nals[i];
+        if (nal->type != 62 /* HEVC_NAL_UNSPEC62 */ || nal->size <= 2)
+            continue;
+        unsigned slot = s->dovi_stash_next++ % FF_ARRAY_ELEMS(s->dovi_stash);
+        av_freep(&s->dovi_stash[slot].rpu);
+        s->dovi_stash[slot].size = 0;
+        s->dovi_stash[slot].rpu = av_memdup(nal->data + 2, nal->size - 2);
+        if (!s->dovi_stash[slot].rpu)
+            return;
+        s->dovi_stash[slot].size = nal->size - 2;
+        s->dovi_stash[slot].pts = pkt->pts;
+        if (!s->dovi_logged_stash) {
+            s->dovi_logged_stash = 1;
+            av_log(avctx, AV_LOG_INFO, "mediacodec: DOVI RPU found "
+                   "(cfg profile %d)\n", s->dovi_ctx.cfg.dv_profile);
+        }
+    }
+}
+
+static int mediacodec_dovi_receive(AVCodecContext *avctx,
+                                   MediaCodecH264DecContext *s,
+                                   AVFrame *frame, bool wait)
+{
+    int ret = ff_mediacodec_dec_receive(avctx, s->ctx, frame, wait);
+    if (ret != 0 || avctx->codec_id != AV_CODEC_ID_HEVC ||
+        frame->pts == AV_NOPTS_VALUE)
+        return ret;
+    /* Like hevcdec: parse every RPU belonging to this frame (updating the
+     * DOVI context), then attach the resulting state once. */
+    int parsed = 0;
+    for (int i = 0; i < FF_ARRAY_ELEMS(s->dovi_stash); i++) {
+        if (!s->dovi_stash[i].rpu || s->dovi_stash[i].pts != frame->pts)
+            continue;
+        if (ff_dovi_rpu_parse(&s->dovi_ctx, s->dovi_stash[i].rpu,
+                              s->dovi_stash[i].size,
+                              avctx->err_recognition) == 0)
+            parsed = 1;
+        av_freep(&s->dovi_stash[i].rpu);
+        s->dovi_stash[i].size = 0;
+        s->dovi_stash[i].pts = AV_NOPTS_VALUE;
+    }
+    if (parsed && ff_dovi_attach_side_data(&s->dovi_ctx, frame) == 0 &&
+        !s->dovi_logged_attach) {
+        s->dovi_logged_attach = 1;
+        av_log(avctx, AV_LOG_INFO, "mediacodec: attaching DOVI metadata\n");
+    }
+    return ret;
+}
+
 static av_cold int mediacodec_decode_close(AVCodecContext *avctx)
 {
