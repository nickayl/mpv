+    mediacodec_dovi_reset(dovi_s);
+    ff_dovi_ctx_unref(&dovi_s->dovi_ctx);
+    ff_h2645_packet_uninit(&dovi_s->dovi_pkt);
     MediaCodecH264DecContext *s = avctx->priv_data;
 
     ff_mediacodec_dec_close(avctx, s->ctx);
